rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Match users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Match subcollection customCards
      match /customCards/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
